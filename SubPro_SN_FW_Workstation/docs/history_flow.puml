@startuml History Screen Flow

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityFontColor #111111
skinparam ArrowColor #555555
skinparam ActivityDiamondBackgroundColor #e8e8e8
skinparam ActivityDiamondBorderColor #555555
skinparam ActivityDiamondFontColor #111111
skinparam NoteBackgroundColor #ddeeff
skinparam NoteBorderColor #5588bb
skinparam NoteFontColor #111111
skinparam BackgroundColor #ffffff
skinparam swimlaneBorderColor #aaaaaa
skinparam swimlaneBackgroundColor #fafafa

title History Screen — View, Filter, Detail, Export

|History Screen|

start

:Navigate to History;

:Load all units from DB\ndb.get_units() — ordered newest first;
note right
  Columns: Timestamp, Product SN, Variant,
  FW Found, Flashed, FW Final, Parts, Result
  Parts shown as min(scanned, required) / required
end note

:Display table rows\n(PASS = green, FAIL = red, INCOMPLETE = grey);

fork

  :|Filter|
  :Enter From date (YYYY-MM-DD);
  :Enter To date (YYYY-MM-DD);
  :Enter SN search string (partial match);
  :Press Apply;
  :db.get_units(product_sn_filter, date_from, date_to);
  :Table refreshed with filtered rows;
  :Status bar shows record count;

fork again

  :|Detail Popup|
  :Press > on any row;
  :Popup opens with full unit detail;
  note right
    Shows all columns plus
    each part: name = SN
    [re-assigned from <prior_product_sn>]
    if applicable
  end note
  :Press Close or tap outside;
  :Popup dismissed;

fork again

  :|CSV Export|
  :Press Export CSV;
  :tkinter folder-picker dialog opens\n(topmost, above Kivy window);

  if (Folder selected?) then (No — cancelled)
    :No file written;
  else (Yes)
    :Apply current filters\n(same SN / date range as table view);
    :Write subpro_export_YYYYMMDD_HHMMSS.csv;
    note right
      One row per unit.
      Parts column: name=SN; name=SN
      Re-assigned parts append
      [reassigned from <product_sn>]
    end note
    :Status bar: "Exported N records to <file>";
  endif

end fork

|History Screen|
:Operator continues browsing or navigates away;
stop

@enduml
